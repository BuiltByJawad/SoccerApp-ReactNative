# ── Database ──────────────────────────────────────────────
# Postgres connection string (required)
# Local:   postgresql://postgres:postgres@localhost:5432/soccerapp
# Hosted:  postgresql://USER:PASSWORD@HOST:5432/DBNAME?sslmode=require
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/soccerapp

# ── Session ──────────────────────────────────────────────
# Secret key for express-session cookies (required)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=replace-with-a-long-random-string

# ── Server ───────────────────────────────────────────────
# Node environment: development | production
NODE_ENV=development

# Port the server listens on (defaults to 5000)
PORT=5000

# ── Cloudinary ───────────────────────────────────────────
# Image upload service (required for venue/profile images)
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# ── SSLCommerz ───────────────────────────────────────────
# Payment gateway (sandbox defaults for testing)
SSLCOMMERZ_STORE_ID=testbox
SSLCOMMERZ_STORE_PASSWORD=qwerty
SSLCOMMERZ_IS_LIVE=false