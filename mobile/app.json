{
  "expo": {
    "name": "Sports Booking",
    "slug": "sports-booking",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "sportsbooking",
    "userInterfaceStyle": "dark",
    "splash": {
      "backgroundColor": "#0A0E17"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.sportsbooking.app"
    },
    "android": {
      "package": "com.sportsbooking.app",
      "adaptiveIcon": {
        "backgroundColor": "#0A0E17"
      }
    },
    "web": {
      "bundler": "metro",
      "output": "single",
      "favicon": "./assets/icon.png"
    },
    "plugins": ["expo-router"],
    "experiments": {
      "typedRoutes": true
    }
  }
}
